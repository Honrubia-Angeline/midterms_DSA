<Window x:Class="Finals_DSA.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Finals_DSA"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

    <Grid Background="LightPink">
        <TextBlock Text="Shopping Cart System" HorizontalAlignment="Center" VerticalAlignment="Top" FontSize="24"/>
        <TextBlock Text="Available Items" HorizontalAlignment="Center" VerticalAlignment="Top" FontSize="15" Margin="0,53,0,0"/>
        <TextBlock Text="Shopping Cart" HorizontalAlignment="Center" VerticalAlignment="Top" FontSize="15" Margin="0,210,0,0"/>
        <DataGrid x:Name="myGridData" ItemsSource="{Binding Products}" AutoGenerateColumns = "False" Margin="10,75,10,232" RenderTransformOrigin="0.505,-0.319" >

            <DataGrid.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform AngleX="1.202"/>
                    <RotateTransform/>
                    <TranslateTransform X="-0.864"/>
                </TransformGroup>
            </DataGrid.RenderTransform>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="*"/>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                <DataGridTextColumn Header="Price" Binding="{Binding Price}" Width="*"/>

            </DataGrid.Columns>
        </DataGrid>

        <DataGrid x:Name="myGridData2" ItemsSource="{Binding btnAddtoCart_Click}" AutoGenerateColumns = "False" Margin="10,235,10,112" RenderTransformOrigin="0.505,-0.319" >
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="*"/>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                <DataGridTextColumn Header="Price" Binding="{Binding Price}" Width="*"/>

            </DataGrid.Columns>
        </DataGrid>

        <StackPanel  Orientation="Horizontal" HorizontalAlignment="Left" Margin="-10,241,0,0" VerticalAlignment="Top" Width="800" Height="161">
            <StackPanel Orientation="Vertical" HorizontalAlignment="Left" Margin="12,100,0,0" VerticalAlignment="Top">
                <Label Content="Id" HorizontalAlignment="Left"  FontSize="15"/>
                <TextBox x:Name="txtId" Height="20" Width="100"/>
            </StackPanel>

            <StackPanel Orientation="Vertical" HorizontalAlignment="Left" Margin="10,100,0,0" VerticalAlignment="Top">
                <Label Content="Name" HorizontalAlignment="Left" FontSize="15"/>
                <TextBox x:Name="txtName" Height="20" Width="100"/>
            </StackPanel>

            <StackPanel Orientation="Vertical" HorizontalAlignment="Left" Margin="10,100,0,0" VerticalAlignment="Top">
                <Label Content="Description" HorizontalAlignment="Left"  FontSize="15"/>
                <TextBox x:Name="txtDescription" Height="20" Width="100"/>
            </StackPanel>

            <StackPanel Orientation="Vertical" HorizontalAlignment="Left" Margin="10,100,0,0" VerticalAlignment="Top">
                <Label Content="Price" HorizontalAlignment="Left" FontSize="15"/>
                <TextBox x:Name="txtPrice" Height="20" Width="100"/>
            </StackPanel>

        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="458,269,0,0" VerticalAlignment="Top" Width="800" Height="155" RenderTransformOrigin="0.453,0.543">
            <Button x:Name="btnAdd" Content="Add" HorizontalAlignment="Left" Margin="12,100,0,0" VerticalAlignment="Top" Width="50" Height="20" Click="btnAdd_Click"/>
            <Button x:Name="btnRemove" Content="Remove" HorizontalAlignment="Left" Margin="12,100,0,0" VerticalAlignment="Top" Width="50" Click="btnRemove_Click"/>
            <Button x:Name="btnClear" Content="Clear" HorizontalAlignment="Left" Margin="12,100,0,0" VerticalAlignment="Top" Width="50" Click="btnClear_Click"/>
            <Button x:Name="btnnAddtoCart" Content="Add to Cart" HorizontalAlignment="Left" Margin="12,100,0,0" VerticalAlignment="Top" Width="70" Click="btnAddtoCart_Click"/>
        </StackPanel>
    </Grid>

</Window>
